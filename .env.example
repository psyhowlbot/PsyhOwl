# Telegram
# ВАЖНО: не вставляйте токены в публичный код и GitHub.
# Токен, который был отправлен в чат, лучше перевыпустить через @BotFather.
TELEGRAM_BOT_TOKEN=PASTE_NEW_TELEGRAM_BOT_TOKEN_HERE
ADMIN_TELEGRAM_IDS=123456789
# Эти пользователи автоматически получают админ-доступ при первом /start.
# ID надёжнее username. ID @twystedgeniusbaby можно добавить позже через запятую.
AUTO_ADMIN_TELEGRAM_IDS=8707664475
AUTO_ADMIN_TELEGRAM_USERNAMES=bo0odyaa,twystedgeniusbaby
PUBLIC_APP_URL=https://your-domain.com

# OpenAI
OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_REASONING_EFFORT=low

# Product / limits
PRODUCT_NAME=Совёнок Premium
PRICE_RUB=12990
DAILY_LIMIT_SECONDS=3600
MONTHLY_LIMIT_SECONDS=108000
TRIAL_SECONDS=600

# Server
PORT=3000
NODE_ENV=production
REQUIRE_TELEGRAM_AUTH=true
TRUST_PROXY=1
